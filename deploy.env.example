# ── deploy.env.example ──────────────────────────────────────────────────────
# Copy this file to deploy.env and fill in real values before running:
#
#   cp deploy.env.example deploy.env
#   docker compose --env-file deploy.env up --build -d
#
# NEVER commit deploy.env to source control. It is already in .gitignore.

# ── Database ────────────────────────────────────────────────────────────────
# Strong password for the Postgres superuser created by the postgres container.
POSTGRES_PASSWORD=change-me-strong-password

# ── JWT secrets ─────────────────────────────────────────────────────────────
# Use at least 32 random characters. Generate with:
#   openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars

# ── Public URLs ──────────────────────────────────────────────────────────────
# The URL browsers will use to reach the API.
# On a GCE VM replace <EXTERNAL_IP> with your VM's external IP address.
# Example: http://34.123.45.67:3001
NEXT_PUBLIC_API_URL=http://<EXTERNAL_IP>:3001

# The URL of the web frontend (used for CORS on the API).
# Example: http://34.123.45.67:3000
FRONTEND_URL=http://<EXTERNAL_IP>:3000
ADMIN_URL=http://<EXTERNAL_IP>:3002
